# ── LLM (OpenRouter) ──────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys  (starts with sk-or-v1-)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Free & capable models on OpenRouter (pick one):
#   google/gemma-2-9b-it:free
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
# Paid but most reliable for multi-step agents:
#   openai/gpt-4o-mini
OPENAI_MODEL_NAME=google/gemma-2-9b-it:free

# Used automatically when the primary model hits a rate/daily-token limit (429).
# Provider quotas are per-model, so a smaller model usually still has budget.
# On Groq use: llama-3.1-8b-instant
OPENAI_FALLBACK_MODEL_NAME=llama-3.1-8b-instant

# Per-request timeout for LLM calls (seconds). Prevents a hung/blackholed
# connection from stalling a run for the client library's default (10 min) —
# failing fast lets the retry/fallback logic kick in instead.
OPENAI_TIMEOUT_SECONDS=25

# Number of self-critique rounds (0-2) to run during SCHEDULED drafts.
# Each round roughly adds one more full-output LLM call per agent.
# Interactive runs control this per-request via the Self-review rounds
# selector in the UI.
SCHEDULED_SELF_CRITIQUE_ROUNDS=0


# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────────
# NOTE: Use a Google App Password — NOT your Gmail login password.
# Get one at: https://myaccount.google.com/apppasswords (16 chars, no spaces)
# ⚠️  REMINDER: Set these before using the approval workflow or scheduler.
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=dummy-google-app-password
NOTIFY_EMAIL=your-gmail@gmail.com


# ── App URL ────────────────────────────────────────────────────────────────────
# Used for review links in emails.  Change to your ngrok/server URL in production.
APP_BASE_URL=http://localhost:8000


# ── LinkedIn ───────────────────────────────────────────────────────────────────
# ⚠️  REMINDER: Set these before using the publish workflow.
# Tokens expire every ~60 days — a 401 means you need to re-run OAuth.
# Setup:
#   1. Create a LinkedIn Developer app at https://developer.linkedin.com
#   2. Add products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
#   3. OAuth scope: openid profile w_member_social
#   4. Get LINKEDIN_PERSON_URN from: GET https://api.linkedin.com/v2/userinfo  (field: sub)
LINKEDIN_ACCESS_TOKEN=dummy-linkedin-token
LINKEDIN_PERSON_URN=urn:li:person:dummy


# ── Medium ─────────────────────────────────────────────────────────────────────
# Medium's API is CLOSED to new integrations since 1 Jan 2025.
# No new tokens are issued. Leave empty unless you have a pre-2025 legacy token.
# Medium publishing is a manual paste flow — the 9:00 AM email includes the markdown.
MEDIUM_TOKEN=


# ── Scheduler ─────────────────────────────────────────────────────────────────
# true  = APScheduler runs draft @ 8:30 IST and publish @ 9:00 IST internally.
# false = Flip this once Hermes Agent is handling scheduling (Phase 4),
#         to prevent double-firing.
ENABLE_INTERNAL_SCHEDULER=true
