# Get your key at https://openrouter.ai/keys  (starts with sk-or-v1-)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Free & capable models on OpenRouter (pick one):
#   google/gemma-2-9b-it:free        ← good free option
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
# Paid but most reliable for ReAct agents:
#   openai/gpt-3.5-turbo
#   openai/gpt-4o-mini
OPENAI_MODEL_NAME=google/gemma-2-9b-it:free